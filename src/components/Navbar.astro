---
const links = [
  { href: "/#mudanzas", label: "Mudanzas Particulares" },
  { href: "/#guardamuebles", label: "Guardamuebles" },
  { href: "/nosotros", label: "Nosotros" },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 w-full z-50
         transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
>
  <nav
    id="navbar-inner"
    class="mx-auto max-w-7xl px-6 py-3
           flex items-center justify-between
           rounded-b-2xl
           bg-white/90 md:bg-white/80
           md:backdrop-blur-lg
           shadow-lg
           transition-all duration-300"
  >
    <!-- LOGO -->
    <a href="/" class="flex items-center">
      <img
        src="/logo-sisa.webp"
        alt="Mudanzas SISA"
        class="h-16 md:h-20 w-auto object-contain"
        loading="eager"
      />
    </a>

    <!-- LINKS DESKTOP -->
    <ul
      id="nav-links"
      class="hidden md:flex gap-10 font-medium text-gray-800"
    >
      {links.map((l) => (
        <li class="relative group">
          <a
            href={l.href}
            data-link
            class="transition-colors duration-200"
          >
            {l.label}
          </a>

          <span
            class="absolute left-0 -bottom-1 h-[2px] w-0
                   bg-red-600
                   transition-all duration-200 ease-out"
          />
        </li>
      ))}
    </ul>

    <!-- HAMBURGUESA -->
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5"
      aria-label="Abrir menú"
    >
      <span class="w-6 h-0.5 bg-gray-900"></span>
      <span class="w-6 h-0.5 bg-gray-900"></span>
      <span class="w-6 h-0.5 bg-gray-900"></span>
    </button>
  </nav>

  <!-- MENU MOBILE -->
  <div
    id="mobile-menu"
    class="md:hidden absolute top-full left-0 w-full
           bg-white
           shadow-xl
           border-t border-black/5
           opacity-0 pointer-events-none
           transition-opacity duration-200"
  >
    <ul class="flex flex-col text-center py-6 gap-6 font-medium text-gray-800">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="hover:text-red-600 transition-colors duration-200"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {

  const navbar = document.getElementById("navbar");
  const navLinks = document.querySelectorAll("[data-link]");
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  if (!navbar) return;

  const currentPath = window.location.pathname;
  const isHome = currentPath === "/";
  const hero = document.querySelector("section");

  let heroHeight = hero ? hero.offsetHeight : 0;
  let ticking = false;

  // -----------------------------
  // NAVBAR + ACTIVE LOGIC (OPTIMIZADO)
  // -----------------------------

  function update() {

    // 🔹 Mostrar / ocultar navbar
    if (isHome && hero) {
      const scrolledPastHero = window.scrollY > heroHeight - 80;

      navbar.classList.toggle("opacity-0", !scrolledPastHero);
      navbar.classList.toggle("-translate-y-full", !scrolledPastHero);
      navbar.classList.toggle("opacity-100", scrolledPastHero);
      navbar.classList.toggle("translate-y-0", scrolledPastHero);
    }

    // 🔹 Active links (más liviano)
    const hash = window.location.hash;

    navLinks.forEach(link => {
      const underline = link.nextElementSibling;
      link.classList.remove("text-red-600");
      if (underline) underline.style.width = "0%";
    });

    navLinks.forEach(link => {
      const href = link.getAttribute("href");

      // Página normal
      if (!href.includes("#") && href === currentPath) {
        activate(link);
      }

      // Home con hash
      if (isHome && hash && href === "/" + hash) {
        activate(link);
      }
    });
  }

  function activate(link) {
    const underline = link.nextElementSibling;
    link.classList.add("text-red-600");
    if (underline) underline.style.width = "100%";
  }

  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
      ticking = true;
    }
  }

  if (!isHome) {
    navbar.classList.add("opacity-100", "translate-y-0");
  } else {
    navbar.classList.add("opacity-0", "-translate-y-full");
  }

  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("hashchange", update);

  update();

  // -----------------------------
  // MOBILE MENU
  // -----------------------------

  menuBtn?.addEventListener("click", () => {
    const open = mobileMenu.classList.contains("opacity-100");

    mobileMenu.classList.toggle("opacity-100", !open);
    mobileMenu.classList.toggle("pointer-events-auto", !open);
    mobileMenu.classList.toggle("opacity-0", open);
    mobileMenu.classList.toggle("pointer-events-none", open);
  });

});
</script>