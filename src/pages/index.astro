---
import BaseLayout from "../layouts/BaseLayout.astro";
import CurveDivider from "../components/ui/CurveDivider.astro";
import Hero from "../components/Hero.astro";
import Mudanzas from "../components/Mudanzas.astro";
import PresupuestoCTA from "../components/PresupuestoCTA.astro";
import Servicios from "../components/Servicios.astro";
import Flota from "../components/Flota.astro";
import Guardamuebles from "../components/Guardamuebles.astro";
import Resenas from "../components/Resenas.astro";
import Clientes from "../components/Clientes.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import ContactModal from "../components/ContactModal.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Mudanzas SISA | Mudanzas seguras en CABA y todo el país">

  <!-- HERO -->
  <Hero />
  <CurveDivider />

  <!-- MUDANZAS -->
   <section id="mudanzasparticulares">
     <Mudanzas />
    </section>

  <!-- PRESUPUESTO CTA -->
  <PresupuestoCTA />
  <ContactModal />
  <CurveDivider />

  <!-- SERVICIOS -->
  <Servicios />
  <CurveDivider />

  <!-- FLOTA -->
  <Flota />
  <CurveDivider />

  <!-- GUARDAMUEBLES -->
  <section id="guardamuebles">
    <Guardamuebles />
    <CurveDivider />
  </section>
  <!-- RESEÑAS -->
  <Resenas />

  <!-- CLIENTES -->
  <Clientes />

  <!-- BOTÓN FLOTANTE WHATSAPP -->
  <WhatsAppFloat />

  <!-- FOOTER -->
  <CurveDivider />


</BaseLayout>